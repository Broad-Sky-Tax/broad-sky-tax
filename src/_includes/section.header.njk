{% for item in collections.sections %}
  {% if item.data.type === 'header' %}
    <div class="flex flex-col justify-center h-full py-12">
      <div class="self-center items-center flex flex-col w-full md:w-5/6 xl:w-2/3 px-4 sm:px-0">
        <div class="w-full text-center sm:text-left px-8 py-8 bg-white/75 backdrop-blur-md rounded-2xl shadow-2xl border border-white/20">
          <div class="mb-4 text-brand [&>h1]:text-4xl [&>h1]:font-bold [&>h1]:tracking-widest [&>h1]:mb-4 [&>h2]:text-2xl [&>h2]:font-semibold [&>h2]:mb-4 [&>ul]:list-disc [&>ul]:pl-5 [&>ul]:space-y-2 [&>ul]:mb-8 [&_li]:text-lg [&_p]:text-lg [&_p]:mt-8 text-left">
            {{ item.templateContent | safe }}
          </div>
          <div class="flex flex-row w-full justify-center sm:justify-start mt-6">
            <a class="px-10 py-3 text-white font-semibold bg-accent-500 rounded-full shadow-md text-lg transition-all duration-300 hover:bg-accent-600 hover:-translate-y-1 hover:shadow-lg" href="#about">
              More Information
            </a>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
{% endfor %}